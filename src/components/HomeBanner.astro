---
interface Props {
  avatarUrl?: string
}
const { avatarUrl } = Astro.props
---

<div class="home-banner my-12 flex flex-col md:flex-row items-center gap-10 md:gap-8 lg:gap-10">
  {
    avatarUrl && (
      <img
        src={avatarUrl}
        alt="Patrick Erichsen"
        class="rounded-full w-36 h-36 md:w-32 md:h-32 lg:w-36 lg:h-36 shrink-0"
      />
    )
  }
  <div class="home-bio text-foreground-muted text-center md:text-right md:flex-1">
    <slot />
  </div>
</div>

<style is:global>
  .home-banner {
    width: 100%;
  }

  @media (min-width: 1024px) {
    .home-bio p:first-child {
      white-space: nowrap;
    }
  }

  .home-bio p + p {
    margin-top: 1rem;
  }

  .home-bio a {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .home-bio a:hover {
    text-decoration-thickness: 2px;
  }
</style>
