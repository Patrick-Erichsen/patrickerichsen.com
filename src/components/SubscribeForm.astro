<section class="subscribe-form" aria-labelledby="subscribe-heading">
  <div>
    <h2 id="subscribe-heading">Subscribe</h2>
    <p>Get new posts by email.</p>
  </div>
  <form
    action="https://buttondown.com/api/emails/embed-subscribe/erichsen"
    method="post"
    target="popupwindow"
    class="subscribe-form-fields"
  >
    <label for="subscribe-email">Email</label>
    <div>
      <input
        id="subscribe-email"
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder="you@example.com"
      />
      <input type="hidden" value="1" name="embed" />
      <button type="submit">Subscribe</button>
    </div>
  </form>
</section>

