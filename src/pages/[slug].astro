---
import type { GetStaticPaths } from 'astro'
import Layout from '@layouts/Layout.astro'
import { getSortedPosts, dateString } from '@utils'
import { render } from 'astro:content'
import SubscribeForm from '@components/SubscribeForm.astro'
export const getStaticPaths = (async () => {
  const posts = await getSortedPosts()
  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      previousPost: posts[index + 1],
      nextPost: posts[index - 1],
    },
  }))
}) satisfies GetStaticPaths

const { post, previousPost, nextPost } = Astro.props
const postData = post.data
const { Content: PostContent } = await render(post)
---

<Layout
  title={postData.title}
  description={postData.description}
  author={postData.author}
  tags={postData.tags}
>
  <article class="py-12" data-pagefind-body>
    <h1 class="text-2xl font-medium mb-2">
      {postData.title}
    </h1>
    {
      postData.subtitle && (
        <p class="text-foreground-muted text-sm mb-3">
          {postData.subtitle}
          {postData.subtitleUrl && (
            <a href={postData.subtitleUrl} target="_blank" rel="noreferrer">
              {postData.subtitleUrlText || postData.subtitleUrl}
            </a>
          )}
        </p>
      )
    }
    <p class="text-foreground-muted text-sm mb-12">
      {dateString(postData.published)}
    </p>
    <div class="prose-custom">
      <PostContent />
    </div>
    <SubscribeForm />
    {
      (previousPost || nextPost) && (
        <nav
          class="mt-12 border-y border-foreground/15 py-6 text-sm"
          aria-label="Post navigation"
        >
          <div class="grid gap-6 sm:grid-cols-2">
            {previousPost && (
              <a
                href={`/${previousPost.id}`}
                class="group no-underline text-left"
                rel="prev"
              >
                <span class="block text-foreground-muted mb-1">&larr; Previous Post</span>
                <span class="underline underline-offset-2 group-hover:decoration-2">
                  {previousPost.data.title}
                </span>
              </a>
            )}
            {nextPost && (
              <a
                href={`/${nextPost.id}`}
                class:list={[
                  'group no-underline text-left sm:text-right',
                  !previousPost && 'sm:col-start-2',
                ]}
                rel="next"
              >
                <span class="block text-foreground-muted mb-1">Next Post &rarr;</span>
                <span class="underline underline-offset-2 group-hover:decoration-2">
                  {nextPost.data.title}
                </span>
              </a>
            )}
          </div>
        </nav>
      )
    }
  </article>
</Layout>
